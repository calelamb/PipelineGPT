  "prompt": "Create a supplier performance dashboard with KPIs for total orders, average defect rate, and on-time delivery percentage. Include a bar chart of defect rate by supplier, a line chart of delivery trends over time, a pie chart of orders by region, and a supplier details table. Add filters for region and category.",
  "result": {
    "app_definition": {
      "app_title": "Supplier Performance Dashboard",
      "app_description": "Monitor supplier performance with key KPIs, defect rates, delivery trends, and regional order distribution.",
      "components": [
        {
          "id": "kpi_total_orders",
          "type": "kpi_card",
          "title": "Total Orders",
          "sql_query": "SELECT COUNT(DISTINCT order_id) AS total_orders FROM supply_chain;",
          "config": {
            "value_column": "total_orders",
            "metric_name": "Total Orders",
            "format": "number"
          }
        },
        {
          "id": "kpi_avg_defect_rate",
          "type": "kpi_card",
          "title": "Average Defect Rate",
          "sql_query": "SELECT AVG(defect_rate) AS avg_defect_rate FROM supply_chain;",
          "config": {
            "value_column": "avg_defect_rate",
            "metric_name": "Average Defect Rate",
            "format": "percentage"
          }
        },
        {
          "id": "kpi_on_time_delivery",
          "type": "kpi_card",
          "title": "On-Time Delivery Percentage",
          "sql_query": "SELECT CASE WHEN COUNT(*) = 0 THEN 0 ELSE 100.0 * SUM(on_time_delivery) * 1.0 / COUNT(*) END AS on_time_delivery_pct FROM supply_chain;",
          "config": {
            "value_column": "on_time_delivery_pct",
            "metric_name": "On-Time Delivery %",
            "format": "percentage"
          }
        },
        {
          "id": "bar_defect_by_supplier",
          "type": "bar_chart",
          "title": "Defect Rate by Supplier",
          "sql_query": "SELECT supplier, AVG(defect_rate) AS avg_defect_rate FROM supply_chain GROUP BY supplier ORDER BY avg_defect_rate DESC;",
          "config": {
            "x_axis": "supplier",
            "y_axis": "avg_defect_rate",
            "format": "percentage",
            "sort_column": "avg_defect_rate",
            "sort_order": "desc"
          }
        },
        {
          "id": "line_delivery_trend",
          "type": "line_chart",
          "title": "Delivery Days Trend Over Time",
          "sql_query": "SELECT strftime(order_date, '%Y-%m') AS order_month, AVG(delivery_days) AS avg_delivery_days FROM supply_chain GROUP BY order_month ORDER BY order_month;",
          "config": {
            "x_axis": "order_month",
            "y_axis": "avg_delivery_days",
            "format": "number",
            "sort_column": "order_month",
            "sort_order": "asc"
          }
        },
        {
          "id": "pie_orders_by_region",
          "type": "pie_chart",
          "title": "Orders by Region",
          "sql_query": "SELECT region, COUNT(DISTINCT order_id) AS total_orders FROM supply_chain GROUP BY region ORDER BY total_orders DESC;",
          "config": {
            "x_axis": "region",
            "y_axis": "total_orders",
            "format": "number"
          }
        },
        {
          "id": "table_supplier_details",
          "type": "table",
          "title": "Supplier Details",
          "sql_query": "SELECT supplier, region, category, COUNT(DISTINCT order_id) AS total_orders, SUM(quantity) AS total_quantity, AVG(defect_rate) AS avg_defect_rate, AVG(delivery_days) AS avg_delivery_days, SUM(on_time_delivery) AS on_time_deliveries, CASE WHEN COUNT(*) = 0 THEN 0 ELSE 100.0 * SUM(on_time_delivery) * 1.0 / COUNT(*) END AS on_time_delivery_pct, SUM(total_cost) AS total_cost, SUM(shipping_cost) AS total_shipping_cost, SUM(warehouse_cost) AS total_warehouse_cost FROM supply_chain GROUP BY supplier, region, category ORDER BY total_orders DESC;",
          "config": {
            "columns": [
              "supplier",
              "region",
              "category",
              "total_orders",
              "total_quantity",
              "avg_defect_rate",
              "avg_delivery_days",
              "on_time_deliveries",
              "on_time_delivery_pct",
              "total_cost",
              "total_shipping_cost",
              "total_warehouse_cost"
            ],
            "sort_column": "total_orders",
            "sort_order": "desc",
            "format": "number"
          }
        }
      ],
